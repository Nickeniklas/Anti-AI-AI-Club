  "_meta": {
    "title": "AI Exposure by Occupational Category (22 SOC Major Groups)",
    "sources": [
      {
        "id": "aei-report",
        "name": "Anthropic Economic Index — Labor Market Impacts",
        "url": "https://huggingface.co/datasets/Anthropic/EconomicIndex",
        "license": "CC-BY",
        "retrieved": "2026-06-05",
        "notes": "Observed exposure for seven categories (Computer and Mathematical, Office and Administrative Support, Business and Financial, Sales, Legal, Arts/Design/Media, and Education and Library) uses employment-weighted averages stated in the published AEI report (Feb–Mar 2026). Every other category, including Production, uses a simple average computed directly from job_exposure.csv, the same basis used for the individual occupations shown under every category regardless of which source its category-level figure comes from. Theoretical capability for eight categories (the same seven, minus Education and Library, plus Management and Architecture and Engineering) is stated directly in the AEI report; the remaining 14 use estimates from Eloundou et al. 2023."
      },
      {
        "id": "eloundou-2023",
        "name": "Eloundou et al. 2023 — GPTs are GPTs",
        "url": "https://doi.org/10.1126/science.adj0998",
        "notes": "Used for theoretical capability estimates where AEI public files do not provide a category-level figure (those files are LFS-stored and not directly fetchable). Eloundou uses O*NET task analysis with GPT-4 and is a lower bound relative to Claude-specific AEI estimates."
      },
      {
        "id": "aei-dataset",
        "name": "Anthropic Economic Index — job_exposure.csv",
        "url": "https://huggingface.co/datasets/Anthropic/EconomicIndex",
        "license": "CC-BY",
        "retrieved": "2026-06-05",
        "notes": "Per-occupation and per-category observed exposure from the released dataset files, used where the AEI report does not give a category-level figure in its prose or figures."
      }
    ],
    "caveat": "Exposure measures where AI shows up in tasks and interactions — not a forecast of job losses. High theoretical exposure in a category means the tasks are ones AI could in principle assist with; it does not determine whether workers in those roles will be displaced or augmented.",
    "colorAxis": "ratio",
    "colorAxisNote": "Per-category automation vs augmentation split is not present in the publicly accessible dataset files. Colour encodes the observed-to-theoretical ratio: how much of the theoretical AI potential for a category is already showing up in real usage. Green = AI is already highly active in this category relative to its ceiling. Coral = much of the theoretical potential is not yet realised. This is a usage-intensity measure, not a judgment of whether the effect is good or bad for workers.",
    "aggregateAutomationShare": {
      "augmentation": 57,
      "automation": 43,
      "source": "Anthropic Economic Index primitives report, Jan 2026"
    }
  },
